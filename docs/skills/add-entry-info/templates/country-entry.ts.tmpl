// src/data/entryCardGuide.ts 의 ENTRY_CARD_DATA 객체 안에 이 항목을 붙여넣는다.
// 아래는 스켈레톤. <...> 자리는 SKILL.md 의 파라미터로 치환.

<countryCode>: {
    // ① 헤더 국가명 — "국기 이모지 + 한글 국명" + 필요시 괄호
    country: "<국기 이모지> <국명>",

    // ① 상태 배지 큰 텍스트 (한 줄 요약)
    status: "<한 줄 상태 요약>",

    // ① 상태 이모지 — SKILL.md §3 관례 5개 중 하나:
    //   ✅ 완전 무비자 · 신고서 불필요
    //   📱 전자입국신고서/도착카드 필수
    //   ✈️ 전자여행허가 (ETA/ESTA/eTA/NZeTA)
    //   📋 e-Visa / 도착비자
    //   ⚠️ 조건부 · 곧 변경
    statusEmoji: "<이모지>",

    // ① 갱신일 (팝업 우측 "YYYY-MM-DD 기준")
    updatedAt: "<YYYY-MM-DD>",

    // (선택) 렌더 안 됨 — 내부 참조용 대표 공식 사이트 URL
    source: "<https://...>",

    // ③ 입국 요건 표 — SKILL.md §3 "관례 라벨" 우선 사용
    details: [
        { label: "입국신고서", value: "<필요/불필요/시스템명>" },
        { label: "비자",       value: "<무비자 일수 or 비자 종류>" },
        { label: "여권 유효기간", value: "<예: 6개월 이상>" },
        // 필요한 만큼 라벨/값 쌍 추가
    ],

    // ② 경고 (없으면 빈 배열 `[]` 유지 — 필드는 필수)
    // 관례: 앞에 ⚠️ 붙임, 한 줄 문장
    warnings: [
        // "⚠️ ETA 미신청 시 탑승 거부 가능",
    ],

    // ④ 신청 절차 — 무비자 자유 국가는 필드 자체 생략
    // process: [
    //     { step: 1, title: "공식 사이트 접속", description: "<URL 접속 방법>" },
    //     { step: 2, title: "<제목>",        description: "<설명>" },
    //     { step: 3, title: "<제목>",        description: "<설명>" },
    // ],

    // ⑤ 유용한 링크 — 관례상 공식 URL 최소 1개
    links: [
        {
            label: "<링크 텍스트>",
            url: "<https://...>",
            type: "official",              // "official" | "guide" | "blog"
            description: "<선택 설명>",
        },
    ],
},
