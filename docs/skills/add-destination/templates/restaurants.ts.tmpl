import type { RestaurantData } from '../index';

// 이 파일 위치: src/data/cities/<slug>/restaurants.ts
// 치환할 자리: <engName>  — destinations.ts 의 CityData.engName
//
// ═══════════════════════════════════════════════════════════════════════
// 필드 상세 (왜 수집하는가 · 없으면 어떻게 되는가 · 어떤 값을 넣나)
// ═══════════════════════════════════════════════════════════════════════
//
// ▸ name : string   [필수]
//    · 어디에 뜨나: FoodCard 상단 제목
//    · 미제공 시: "식당 이름" fallback (사실상 필수)
//
// ▸ type : RestaurantType   [필수]
//    · 어디에 뜨나: 카드 좌측 이모지 fallback + 카테고리 라벨
//    · 유효값 10개 (FoodCard.tsx:8-20 기준):
//        korean       → 한식  🍚
//        japanese     → 일식  🍣
//        chinese      → 중식  🥡
//        western      → 양식  🍴
//        italian      → 이탈리안  🍝
//        french       → 프렌치  🥐
//        cafe         → 카페  ☕
//        street-food  → 길거리음식  🌭
//        fusion       → 퓨전  🍽️
//        local        → 현지음식  🥘
//    · 미제공 시: "Food" 기본 라벨 + 이모지 없음
//    · 애매할 때 프로젝트 정책 fallback: **`local`** (현지음식)
//
// ▸ city : string   [필수]
//    · 어디에 뜨나: 표시 안 됨 (필터 전용). FoodPicker 가 이 값으로 도시 매칭
//    · 미제공 시: 픽커 목록에서 제외
//    · 어떤 값: destinations.ts 의 engName **정확 일치**
//
// ▸ coordinates : { lat, lng }   [강력 권장]
//    · 어디에 뜨나: 지도 마커 + 앵커 카드 기준 거리 계산
//    · 미제공 시: 지도에서 숨김, 거리 정보 없음
//    · 유효 범위: lat -90~90, lng -180~180 (도시 실제 범위 내)
//    · **수집 절차 (구글지도 원본 매칭 필수)**:
//        1. Google Maps 에서 대상 장소 검색
//        2. 마커 지점 우클릭 → 팝업 최상단 좌표 클릭 → 클립보드 복사
//        3. 형식: `34.6686, 135.5014` → `{ lat: 34.6686, lng: 135.5014 }` 로 옮김
//        4. 자릿수 원본 그대로 유지 (반올림·절삭 금지)
//        5. 검증: Google Maps 검색창에 `<lat>, <lng>` 붙여넣어 원 장소 마커 재확인
//    · 금지: AI 좌표 답변, 위키/블로그 인용, 위성뷰 대충 클릭
//
// ▸ cuisine? : string   [선택]
//    · 어디에 뜨나: 현재 카드에서 직접 렌더 없음 (향후 필터용)
//    · 미제공 시: 무영향
//    · 어떤 값: "라멘", "딤섬", "스테이크" 등 요리 종류 한 단어
//
// ▸ specialty? : string   [선택]
//    · 어디에 뜨나: FoodCard 하단 텍스트
//    · 미제공 시: 텍스트 생략
//    · 어떤 값: 시그니처 메뉴 (예: "돈코츠 라멘", "오마카세")
//
// ▸ priceRange? : string   [선택]
//    · 어디에 뜨나: FoodCard 하단, specialty 다음 (separator | 뒤)
//    · 미제공 시: separator 미표시
//    · 어떤 값: 현지 통화 기호 포함 (예: "¥1,000~2,000", "$20~50", "€15~30")
//
// ▸ michelin? : string   [선택]
//    · 어디에 뜨나: FoodCard 하단, ⭐ 아이콘과 함께 표시
//    · 미제공 시: 미슐랭 섹션 전체 생략
//    · 유효 값 (문자열 자유):
//        "★"          → 1스타
//        "★★"         → 2스타
//        "★★★"        → 3스타
//        "Bib Gourmand" → 미슐랭 빕구르망
//    · 미슐랭 없는 곳은 아예 필드 자체 생략
//
// ▸ reservation? : boolean   [선택]
//    · 어디에 뜨나: 현재 카드에서 직접 렌더 없음 (features 배열에 반영 권장)
//    · 미제공 시: undefined → 표시 안 됨
//    · 값 의미:
//        true  → 예약 필수 (전화·앱)
//        false → 워크인 가능
//    · **프로젝트 정책: 확인 불가 시 필드 자체 생략** (false 대신)
//
// ▸ openingHours? : string   [선택]
//    · 어디에 뜨나: 현재 카드에서 직접 렌더 없음 (향후 타임라인 통합용)
//    · 미제공 시: 무영향
//    · 어떤 값: "11:30-22:00" / "24/7" / "월-금 09:00-18:00"
//
// ▸ features? : string[]   [선택]
//    · 어디에 뜨나: FoodPicker 데이터에 포함되지만 카드에서 직접 렌더 없음
//      (검색 필터용, 향후 확장)
//    · 미제공 시: 무영향
//    · 어떤 값: ["1인 좌석", "영어 메뉴", "24시간"] — 짧은 태그
//
// ▸ icon? : string   [선택]
//    · 어디에 뜨나: 카드 좌측 이모지 (커스텀 지정)
//    · 미제공 시: type 기반 fallback 이모지 사용 (RESTAURANT_TYPE_ICONS)
//    · 어떤 값: 이모지 한 글자 (🍜🥟🍕 등)
//
// ▸ showInInbox? : boolean   [사실상 필수]
//    · 어디에 뜨나: FoodPicker 필터
//    · 미제공 시: undefined → falsy → **픽커에 안 뜸**
//    · **프로젝트 정책: 모든 카드에 `true`** (인박스에 전부 노출)
//
// ═══════════════════════════════════════════════════════════════════════

const restaurants: RestaurantData[] = [
    // 예시 (주석 해제해서 도시 값에 맞게 편집):
    // {
    //     name: "<가게 이름>",
    //     showInInbox: true,
    //     type: "local",                                  // 위 10개 enum 중
    //     city: "<engName>",
    //     coordinates: { lat: 0.0000, lng: 0.0000 },
    //     cuisine: "<대표 요리>",
    //     specialty: "<시그니처 메뉴>",
    //     priceRange: "<현지 통화 가격대>",
    //     openingHours: "<영업시간>",
    //     features: ["<특징1>", "<특징2>"],
    //     icon: "🍽️"
    // },
];

export default restaurants;
