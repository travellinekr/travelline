{
    "framework": "nextjs",
    "buildCommand": "npx next build",
    "installCommand": "npm install --legacy-peer-deps",
    "env": {
        "NEXT_TURBOPACK": "0"
    },
    "crons": [
        {
            "path": "/api/cron/cleanup-photos",
            "schedule": "0 18 * * *"
        },
        {
            "path": "/api/cron/push-trip-reminders",
            "schedule": "0 21 * * *"
        }
    ]
}
